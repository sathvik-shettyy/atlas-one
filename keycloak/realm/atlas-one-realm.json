{
	"realm": "atlas-one",
	"enabled": true,
	"displayName": "ATLAS ONE Identity Engine",
	"loginTheme": "keycloak",
	"registrationAllowed": false,
	"resetPasswordAllowed": true,
	"rememberMe": true,
	"duplicateEmailsAllowed": false,
	"clients": [
		{
			"clientId": "atlas-one-dashboard",
			"name": "ATLAS ONE Dashboard",
			"enabled": true,
			"publicClient": true,
			"standardFlowEnabled": true,
			"redirectUris": [
				"http://localhost:8080/*"
			],
			"webOrigins": [
				"http://localhost:8080"
			],
			"protocol": "openid-connect"
		}
	],
	"roles": {
		"realm": [
			{
				"name": "admin"
			},
			{
				"name": "developer"
			},
			{
				"name": "guest"
			}
		]
	}
}

